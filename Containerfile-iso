FROM quay.io/fedora/fedora-coreos:rawhide

# Install packages needed to fulfill the contract:
RUN dnf install -y \
        dracut-live \
        grub2-efi-x64-cdboot \
        xorriso \
        isomd5sum \
        python3 \
    && dnf clean all

# Regenerate initramfs with the dmsquash-live module so the ISO can boot
# the squashfs root filesystem. 
# DRACUT_NO_XATTR=1 avoids xattr issues in container build environments.
RUN kernel=$(kernel-install list --json pretty | jq -r '.[] | select(.has_kernel == true) | .version') && \
    DRACUT_NO_XATTR=1 dracut -v --force --zstd --reproducible --no-hostonly \
        --add "dmsquash-live dmsquash-live-autooverlay" \
        "/usr/lib/modules/${kernel}/initramfs.img" "${kernel}"

# The contract expects shim/grub2 EFI binaries in /boot/efi/EFI/$VENDOR.
RUN mkdir -p /boot/efi && cp -av /usr/lib/efi/*/*/EFI /boot/efi/

# Tell bootc that the root filesystem type is xfs
RUN mkdir -p /usr/lib/bootc/install
COPY iso-bootc.toml /usr/lib/bootc/install/iso-bootc.toml

# Write the GRUB2 / ISO configuration consumed by image-builder
RUN mkdir -p /usr/lib/bootc-image-builder
COPY iso.yaml /usr/lib/bootc-image-builder/iso.yaml
